---
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"ul"> {
	class?: string | null,
}

const { class: className, ...props } = Astro.props;
---
<ul class="overview-list" class:list={[className]} {...props}>
	<slot />
</ul>

<style is:global>
	.overview-list {
		list-style-type: none;
		padding: 0;
		margin: 0;
	}
	.overview-list li {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.overview-list li:last-of-type {
		margin-bottom: 0;
	}
</style>