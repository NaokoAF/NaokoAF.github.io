---
import {getCollection} from "astro:content";
import {openGraph} from "../config.ts";
import Card from "../components/Card.astro";
import Layout from "../layouts/Layout.astro";
import PostList from "../components/PostList.astro";

const projects = await getCollection("projects", (post) => post.data.unlisted !== true);
---
<Layout
	pageTitle={openGraph.projects.pageTitle}
	title={openGraph.projects.title}
	description={openGraph.projects.description}
	image={openGraph.projects.image}
	pagefindIgnore
>
	<div class="layout-grid__left" slot="left">
		<Card title="stats" icon="lucide/chart-column">
			<div class="stat-list">
				<div class="stat">
					<h3 class="stat__number">{projects.length}</h3>
					<span class="stat__label">project{projects.length === 1 ? '' : 's'}</span>
				</div>
			</div>
		</Card>
	</div>
	<div class="layout-grid__right" slot="right">
		<Card title="projects" icon="lucide/folder-git" id="posts-card">
			<PostList
				posts={
					projects.map((post) => ({
						url: `/projects/${post.id}`,
						title: post.data.title,
						description: post.data.description,
						date: post.data.releasedAt,
						image: post.data.image,
					}))
				}
			/>
		</Card>
	</div>
</Layout>

<style>
	.stat-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
	}

    .stat__number {
        font-size: 2em;
        margin: 0 0 0.5rem;
		color: var(--color-accent);
    }

    .stat__label {
        color: var(--color-text);
    }
</style>