---
import Layout from "../layouts/Layout.astro";
import BlockLink from "../components/BlockLink.astro";
---
<Layout
	title="404"
	description="page not found."
	pagefindIgnore
>
	<div class="not-found">
		<h1 class="not-found__header">404</h1>
		<p class="not-found__description">oops</p>
		<BlockLink class="not-found__back" href="/">← take me home</BlockLink>
	</div>
</Layout>

<style>
	.not-found {
		display: flex;
		height: 70vh;
		justify-content: center;
		align-items: center;
		width: 100%;
		text-align: center;
		flex-direction: column;
	}

	.not-found__header {
		font-size: 4rem;
		margin: 0;
		color: var(--color-accent);
	}

	.not-found__description {
		font-size: 1.25em;
		margin: 0;
	}

	.not-found__back {
		margin-top: 1rem;
	}
</style>